# Cairn configuration — copy to `.env` (project) or ~/.config/cairn/.env (machine-global).
# Precedence: real environment variables > project .env > global .env > built-in defaults.

# --- server ---
# CAIRN_DATA_DIR=/data          # where Cairn keeps its data (default: OS data dir, /data in Docker)
# CAIRN_HOST=127.0.0.1          # serve bind host (use 0.0.0.0 to expose on a network/server)
# CAIRN_PORT=7777               # serve bind port

# --- connecting a personal device to a server ---
# CAIRN_SERVER=http://your-server:7777   # default server for `cairn sync` / `pull` / `contribute`

# --- datastore ---
# Unset CAIRN_HELIX_URL = built-in store under the data dir (single machine, no external service).
# Set it to use a HelixDB server. The docker-compose stack wires the cairn container to its bundled
# Helix automatically (http://helix:8080), so you only set this for a standalone/remote Helix:
# CAIRN_HELIX_URL=http://your-helix-host:6969

# --- docker compose stack (only read by `docker compose`, for the bundled Helix + MinIO) ---
# HELIX_PORT=6969               # host port for direct HelixDB access (maps to container :8080)
# MINIO_ROOT_USER=minioadmin    # credentials for the bundled MinIO that Helix persists to
# MINIO_ROOT_PASSWORD=minioadmin

# --- embeddings (global "embedded LLM" for vector search) ---
# provider: local (default) | openai | ollama | hashing
#   hashing = deterministic, dependency-free feature-hashing (no model/network); used by tests and
#   handy as a zero-setup fallback, but it captures only lexical overlap, not true semantics.
CAIRN_EMBED_PROVIDER=local
# Model id; the local default is all-MiniLM-L6-v2 (384-dim, runs in-process, no API key).
# CAIRN_EMBED_MODEL=all-MiniLM-L6-v2
# For ollama / OpenAI-compatible providers:
# CAIRN_EMBED_URL=http://localhost:11434
# CAIRN_EMBED_API_KEY=sk-...
