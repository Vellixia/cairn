{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "cairn hook PostToolUse",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|StrReplace"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "cairn hook SessionEnd",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "cairn hook SessionStart",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "cairn hook UserPromptSubmit",
            "type": "command"
          }
        ]
      }
    ]
  }
}
